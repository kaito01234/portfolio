<div class="counter-wrapper">
  <span class="counter-label">あなたは</span>
  <span class="counter" id="access-counter">
    <span class="digit">0</span>
    <span class="digit">0</span>
    <span class="digit">0</span>
    <span class="digit">0</span>
    <span class="digit">0</span>
    <span class="digit">0</span>
  </span>
  <span class="counter-label">人目の訪問者です！</span>
</div>

<script>
  import { Counter } from 'counterapi';

  const counter = new Counter({
    workspace: 'kaito01234-portfolio',
    debug: true,
  });

  const counterEl = document.getElementById('access-counter');

  if (counterEl) {
    const digits = counterEl.querySelectorAll('.digit');
    let text: string;
    try {
      const result = await counter.up('visits-counter');
      const count = (result as any).data.up_count as number;
      text = String(count).padStart(digits.length, '0');
    } catch {
      text = 'ERROR!';
    }
    digits.forEach((d, i) => {
      d.textContent = text[i] ?? '';
    });
  }
</script>

<style>
  .counter-wrapper {
    text-align: center;
    margin: 12px 0;
    font-size: 14px;
  }

  .counter {
    display: inline-flex;
    gap: 2px;
    margin: 0 4px;
  }

  .digit {
    display: inline-block;
    width: 20px;
    height: 28px;
    line-height: 28px;
    text-align: center;
    background: #000;
    color: #00ff00;
    font-size: 18px;
    font-weight: bold;
    font-family: 'Courier New', monospace;
    border: 1px solid #333;
  }
</style>
